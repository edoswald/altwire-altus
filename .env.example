# Required
DATABASE_URL=                  # Shared Railway PostgreSQL connection string
ALTWIRE_WP_URL=                # https://altwire.net
ALTWIRE_WP_USER=               # WordPress admin username
ALTWIRE_WP_APP_PASSWORD=       # WordPress Application Password (spaces kept intact)
VOYAGE_API_KEY=                # Voyage AI API key (voyage-3-lite model)
ANTHROPIC_API_KEY=             # For gallery synthesis via Claude Haiku

# Matomo Analytics
ALTWIRE_MATOMO_URL=            # Matomo server URL (e.g. https://matomo.ozmediaservices.com/matomo/)
ALTWIRE_MATOMO_TOKEN_AUTH=     # Matomo API auth token
ALTWIRE_MATOMO_SITE_ID=        # Matomo site ID for altwire.net

# Google Search Console
ALTWIRE_GSC_SERVICE_ACCOUNT_JSON=  # Full JSON service account key (single line)
ALTWIRE_GSC_SITE_URL=              # GSC site URL (e.g. https://altwire.net or sc-domain:altwire.net)

# Better Stack Monitoring
BETTER_STACK_TOKEN=            # Read-only Better Stack API token for uptime monitoring

# OAuth — one env var per named client, with owner/operator identity in the name
# Pattern: OAUTH_CLIENT_ID_<OPERATOR> and OAUTH_CLIENT_SECRET_<OPERATOR>
OAUTH_CLIENT_ID_DEREK=altus-derek
OAUTH_CLIENT_SECRET_DEREK=your-secret-here
OAUTH_CLIENT_ID_STAGING=altus-staging
OAUTH_CLIENT_SECRET_STAGING=staging-secret

# Redirect URI (optional — defaults to <MCP_BASE_URL>/oauth/callback)
OAUTH_REDIRECT_URI=https://your-altus-domain.com/oauth/callback

# Additional allowed redirect URIs beyond the primary (comma-separated)
OAUTH_ALLOWED_REDIRECT_URIS=https://your-altus-domain.com/oauth/callback,https://localhost:3000/oauth/callback

# MCP base URL (used in OAuth discovery endpoint and as fallback redirect base)
MCP_BASE_URL=https://your-altus-domain.com

# Per-client tool allowlists (optional — clients not listed here get full access)
# Format: clientId1:tool1,tool2;clientId2:tool1
OAUTH_CLIENT_TOOLS=

# Optional
PORT=3000                      # Railway sets this automatically
TEST_MODE=false                # Set true to skip live API calls in tests
LOG_LEVEL=info
ALTUS_ADMIN_TOKEN=             # Bearer token for writer REST endpoints (/hal/writer/*)
ALTUS_WRITER_MODEL=            # AI model for writer pipeline (default: claude-sonnet-4-5). gpt-*/o1*/o3* → OpenAI; all else → Anthropic
OPENAI_API_KEY=                # Required only when ALTUS_WRITER_MODEL is set to an OpenAI model

# Editorial Intelligence (Topic Discovery, News Monitor, Performance Tracker)
# No new env vars required — reuses existing:
#   DATABASE_URL                      — PostgreSQL for agent_memory, article_performance, article_assignments
#   ALTWIRE_GSC_SERVICE_ACCOUNT_JSON  — GSC API for opportunity zone, News search type, page performance
#   ALTWIRE_GSC_SITE_URL              — GSC site URL
#   ANTHROPIC_API_KEY                 — Haiku for editorial pitch synthesis
